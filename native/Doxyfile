# Doxyfile - Doxygen Configuration for SV Publisher Native Module
# Run: doxygen Doxyfile

#---------------------------------------------------------------------------
# Project Information
#---------------------------------------------------------------------------

PROJECT_NAME           = "SV Publisher - Native C++ Module"
PROJECT_BRIEF          = "IEC 61850-9-2LE Sampled Values Encoder"
PROJECT_NUMBER         = "1.0.0"
OUTPUT_DIRECTORY       = docs

#---------------------------------------------------------------------------
# Build Configuration  
#---------------------------------------------------------------------------

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ALWAYS_DETAILED_SEC    = YES
FULL_PATH_NAMES        = NO
JAVADOC_AUTOBRIEF      = YES
OPTIMIZE_OUTPUT_FOR_C  = YES
MARKDOWN_SUPPORT       = YES

#---------------------------------------------------------------------------
# Input Files
#---------------------------------------------------------------------------

INPUT                  = src include docs/BACKEND_ARCHITECTURE.md README.md
FILE_PATTERNS          = *.cc *.h *.cpp *.c *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = docs/BACKEND_ARCHITECTURE.md

#---------------------------------------------------------------------------
# Source Browsing
#---------------------------------------------------------------------------

SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES
STRIP_CODE_COMMENTS    = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

#---------------------------------------------------------------------------
# HTML Output
#---------------------------------------------------------------------------

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_COLORSTYLE        = LIGHT
HTML_TIMESTAMP         = YES
GENERATE_TREEVIEW      = YES
TREEVIEW_WIDTH         = 300
SEARCHENGINE           = YES
GENERATE_LATEX         = NO

#---------------------------------------------------------------------------
# Graphs and Diagrams (Optional - requires Graphviz)
#---------------------------------------------------------------------------

HAVE_DOT               = YES
CLASS_DIAGRAMS         = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
DOT_GRAPH_MAX_NODES    = 100
DOT_MULTI_TARGETS      = YES
DOTFILE_DIRS           = docs/graphs

#---------------------------------------------------------------------------
# Preprocessing
#---------------------------------------------------------------------------

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
PREDEFINED             = _WIN32
